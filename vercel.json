{
  "buildCommand": "vite build && mkdir -p api && cp dist/server/index.js api/index.js",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/api/index.js"
    }
  ]
}