{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "vite build && cp -r dist/server dist/client/_server",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "functions": {
    "_server/index.js": {
      "runtime": "edge"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/_server/index.js"
    }
  ]
}
