{
  "buildCommand": "vite build && mkdir -p server-entry && cp dist/server/index.js server-entry/index.js",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",
  "functions": {
    "server-entry/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/|favicon.ico|.*\\..*).*)",
      "destination": "/server-entry/index.js"
    }
  ]
}