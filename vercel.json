{
  "version": 2,
  "buildCommand": "bun run build && mkdir -p api && cp dist/server/index.js api/index.js",
  "installCommand": "bun install",
  "outputDirectory": "dist/client",

  "rewrites": [
    {
      "source": "/((?!assets/|favicon.ico|.*\\..*).*)",
      "destination": "/api/index.js"
    }
  ]
}